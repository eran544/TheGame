{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=TheGameDB;User Id=sa;Password=YOUR_PASSWORD_HERE;TrustServerCertificate=true;",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS",
    "Issuer": "TheGameServer",
    "Audience": "TheGameClient",
    "ExpirationMinutes": 60
  },
  "AIService": {
    "BaseUrl": "http://localhost:8000",
    "TimeoutSeconds": 30
  },
  "GameSettings": {
    "SessionTimeoutMinutes": 10,
    "GameTimeoutMinutes": 90,
    "MaxPlayersPerGame": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}