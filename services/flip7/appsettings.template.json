{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=Flip7DB;Username=postgres;Password=YOUR_PASSWORD_HERE",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS",
    "Issuer": "TheGameServer",
    "Audience": "TheGameClient",
    "ExpirationMinutes": 60
  },
  "AIService": {
    "BaseUrl": "http://localhost:8000",
    "TimeoutSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
