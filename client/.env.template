# React Client Configuration Template
# Copy this file to .env and adjust as needed.
#
# Service URLs default to the dev server's same-origin /svc/* reverse proxy
# (see vite.config.ts) — no CORS, works from any device on the LAN.
# Set these only to call services on absolute URLs instead:
# REACT_APP_AUTH_URL=http://localhost:5002
# REACT_APP_THEGAME_URL=http://localhost:5001
# REACT_APP_FLIP7_URL=http://localhost:5003
# Legacy single-backend fallback for The Game:
# REACT_APP_API_BASE_URL=http://localhost:5001

# Environment
REACT_APP_ENVIRONMENT=development

# Feature Flags
REACT_APP_ENABLE_DEBUG_LOGGING=true
